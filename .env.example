# Challenge 5 - Environment Variables
# Copy this file to .env and fill in the values after deployment

# Azure AI Foundry Project connection string (from deployment output or portal)
PROJECT_CONNECTION_STRING=

# Model deployment name
MODEL_DEPLOYMENT_NAME=gpt-4o

# Azure OpenAI endpoint
AZURE_OPENAI_ENDPOINT=

# APIM Gateway URL for secure inference routing
APIM_GATEWAY_URL=

# MCP Server URL (SSE endpoint)
MCP_SERVER_URL=

# APIM Subscription Key (optional, for direct APIM calls)
APIM_SUBSCRIPTION_KEY=

# Agent display name
AGENT_NAME=Challenge5-Agent
